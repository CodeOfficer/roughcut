# ============================================
# API Keys
# ============================================

# ElevenLabs API Key (REQUIRED)
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
export ELEVENLABS_API_KEY=your_api_key_here

# Google Gemini API Key (REQUIRED)
# Used for generating static images (title slides, conclusion screens, etc.)
# Get your API key from: https://aistudio.google.com/app/apikey
export GEMINI_API_KEY=your_api_key_here

# Anthropic API Key (OPTIONAL)
# Required only if using Claude for script generation or enhancement
# Get your API key from: https://console.anthropic.com/settings/keys
export ANTHROPIC_API_KEY=your_api_key_here


# ============================================
# ElevenLabs Configuration
# ============================================

# Voice ID to use for narration
# Available voices: adam, rachel, domi, bella, antoni, elli, josh, arnold, callum, charlie, etc.
# Find more at: https://elevenlabs.io/app/voice-library
export ELEVENLABS_VOICE_ID=adam

# Model to use for text-to-speech
# Options: eleven_monolingual_v1, eleven_multilingual_v2, eleven_turbo_v2
export ELEVENLABS_MODEL=eleven_monolingual_v1

# Voice stability (0.0 - 1.0)
# Higher values = more consistent, lower = more expressive
export ELEVENLABS_STABILITY=0.75

# Voice similarity boost (0.0 - 1.0)
# Higher values = closer to original voice, lower = more variation
export ELEVENLABS_SIMILARITY_BOOST=0.75


# ============================================
# Gemini Configuration
# ============================================

# Model to use for image generation
# Options: gemini-2.0-flash-exp (recommended), gemini-1.5-pro, gemini-1.5-flash
export GEMINI_MODEL=gemini-2.0-flash-exp

# Default image resolution for generated images
# Format: WIDTHxHEIGHT (e.g., 1920x1080 for Full HD)
export GEMINI_IMAGE_RESOLUTION=1920x1080


# ============================================
# Output Configuration
# ============================================

# Directory where tutorial projects are stored
export OUTPUT_DIR=./tutorials

# Temporary directory for intermediate files
export TEMP_DIR=./tmp


# ============================================
# Tool Paths
# ============================================

# Path to FFmpeg binary
# Default: /usr/local/bin/ffmpeg
# macOS (Homebrew): /opt/homebrew/bin/ffmpeg
# Windows: C:/ffmpeg/bin/ffmpeg.exe
# Linux: /usr/bin/ffmpeg
export FFMPEG_PATH=/usr/local/bin/ffmpeg

# Path where Playwright browsers are installed
# Leave as default unless you need custom browser location
export PLAYWRIGHT_BROWSERS_PATH=./browsers


# ============================================
# Development Settings
# ============================================

# Environment mode
# Options: development, production, test
export NODE_ENV=development

# Logging level
# Options: debug, info, warn, error
export LOG_LEVEL=info
