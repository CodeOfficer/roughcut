{
  "name": "roughcut",
  "version": "3.1.0",
  "description": "Generate RevealJS presentations and videos from markdown with AI narration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "roughcut": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "presentation",
    "revealjs",
    "slides",
    "video",
    "narration",
    "markdown",
    "cli",
    "tts",
    "elevenlabs",
    "playwright",
    "ffmpeg",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/codeofficer/roughcut",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeofficer/roughcut.git"
  },
  "bugs": {
    "url": "https://github.com/codeofficer/roughcut/issues"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "playwright": "^1.42.1",
    "reveal.js": "^5.2.1",
    "sharp": "^0.33.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.24",
    "@types/reveal.js": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
