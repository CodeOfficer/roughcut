{
  "name": "genai-tutorial-factory",
  "version": "1.0.0",
  "description": "Automated tutorial video generation system using AI narration and browser automation",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "direnv exec . tsx src/cli/index.ts",
    "start": "direnv exec . node dist/cli/index.js",
    "tutorial:create": "direnv exec . tsx src/cli/index.ts create",
    "tutorial:narrate": "direnv exec . tsx src/cli/index.ts narrate",
    "tutorial:screenshots": "direnv exec . tsx src/cli/index.ts screenshots",
    "tutorial:build": "direnv exec . tsx src/cli/index.ts build",
    "tutorial:clean": "direnv exec . tsx src/cli/index.ts clean",
    "tutorial:full": "direnv exec . tsx src/cli/index.ts full",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "tutorial",
    "video",
    "automation",
    "elevenlabs",
    "gemini",
    "playwright",
    "ffmpeg",
    "typescript",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@11ty/eleventy-fetch": "^4.0.1",
    "@google/generative-ai": "^0.21.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1",
    "playwright": "^1.42.1",
    "reveal.js": "^5.2.1",
    "sharp": "^0.33.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.24",
    "@types/reveal.js": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
