{
  "name": "genai-tutorial-factory",
  "version": "2.0.0",
  "description": "Generate interactive RevealJS presentations and videos from markdown with AI narration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node dist/cli/index.js dev -i tutorials/full-demo/presentation.md",
    "dev:auto": "node dist/cli/index.js dev -i tutorials/full-demo/presentation.md --auto",
    "dev:cli": "direnv exec . tsx src/cli/index.ts",
    "start": "direnv exec . node dist/cli/index.js",
    "tutorial:build": "direnv exec . tsx src/cli/index.ts build",
    "build:fast": "bash scripts/build-tutorial.sh fast",
    "build:full": "bash scripts/build-tutorial.sh full",
    "build:html": "bash scripts/build-tutorial.sh html",
    "demo": "bash scripts/build-tutorial.sh demo fast",
    "demo:full": "bash scripts/build-tutorial.sh demo full",
    "demo:html": "bash scripts/build-tutorial.sh demo html",
    "test:build": "bash scripts/build-tutorial.sh test fast",
    "test:build:full": "bash scripts/build-tutorial.sh test full",
    "test:build:html": "bash scripts/build-tutorial.sh test html",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "voices": "direnv exec . tsx scripts/list-voices.ts"
  },
  "keywords": [
    "tutorial",
    "video",
    "presentation",
    "revealjs",
    "slides",
    "automation",
    "elevenlabs",
    "playwright",
    "ffmpeg",
    "typescript",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "playwright": "^1.42.1",
    "reveal.js": "^5.2.1",
    "sharp": "^0.33.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.11.24",
    "@types/reveal.js": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
